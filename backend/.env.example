# ============================================
# IPC School System - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================

# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=ipc_school

# JWT Configuration - IMPORTANT: Use strong secret!
# Generate strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_strong_jwt_secret_key_change_this_in_production

# CORS Configuration (for production)
# Comma-separated list of allowed origins
# Example: ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# Security Configuration
# Rate limiting: Max requests per minute
RATE_LIMIT_MAX=100

# Login rate limiting: Max attempts per 15 minutes
LOGIN_RATE_LIMIT_MAX=5

# ============================================
# SECURITY CHECKLIST:
# ============================================
# 1. Change JWT_SECRET to strong random string (64+ chars)
# 2. Change database passwords
# 3. Set NODE_ENV=production in production
# 4. Set ALLOWED_ORIGINS to your frontend URL only
# 5. Enable HTTPS in production
# 6. Regularly rotate JWT_SECRET
# 7. Monitor logs for suspicious activity
# ============================================
